#!/usr/bin/env bash
set -euo pipefail

# Pre-commit hook to regenerate module-index.nix, MODULES.md, and documentation.
# Run AI/code review separately when needed (e.g. before a release).

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"

cd "$REPO_ROOT"

# Always run update.sh before commit
echo "[pre-commit] Running tools/update.sh to ensure modules are up to date..."
if ! "$REPO_ROOT/tools/update.sh"; then
  echo "[pre-commit] Error: update.sh failed. Aborting commit."
  exit 1
fi

# Stage any changes made by update.sh
git add -u

echo "[pre-commit] Done."
exit 0
